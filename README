cat Chuong3_Lap\ trinh\ Shell\ Script.txt | grep string   # tim kiem tu khoa "string"
more 'Chuong3_Lap\ trinh\ Shell\ Script.txt'  # xem file

# Linux
command &> output.txt -> Redirect both stdout and stderr (recommended)
> → stdout
2> → stderr
&> → both

## Common positional & special variables
$0   # Script name
$1   # First argument
$2   # Second argument
$3   # Third argument ...
$@   # All arguments (Keeps each argument separate)
$*   # All arguments (Combines all arguments into one single string )
$#   # Number of arguments

## Process & execution info
$$   # Current script PID (process ID)
$!   # PID of last background process
$?   # Exit status of last command
# Bash Comparison Operators Cheat Sheet

## String Comparison

```bash
=     # equal
==    # equal (preferred in [[ ]])
!=    # not equal
<     # less than (lexicographically)
>     # greater than (lexicographically)
```

### Example

```bash
if [ "$a" = "$b" ]; then
    echo "Equal"
fi
```

---

## 🔹 Integer (Number) Comparison

```bash
-eq   # equal
-ne   # not equal
-lt   # less than
-le   # less than or equal
-gt   # greater than
-ge   # greater than or equal
```

### Example

```bash
if [ "$a" -gt 10 ]; then
    echo "Greater than 10"
fi
```

---

## 🔹 File Tests

```bash
-e    # file exists
-f    # regular file exists
-d    # directory exists
-r    # readable
-w    # writable
-x    # executable
-s    # file not empty
```

### Example

```bash
if [ -f "file.txt" ]; then
    echo "File exists"
fi
```

---

## 🔹 Logical Operators

```bash
&&    # AND
||    # OR
!     # NOT
```

### Example

```bash
if [ "$a" -gt 5 ] && [ "$a" -lt 20 ]; then
    echo "Between 5 and 20"
fi
```

---

## 🔹 Recommended Modern Syntax

```bash
if [[ "$a" == "$b" ]]; then
    echo "Equal"
fi
```

---

## ⚡ Quick Summary

* Strings → `=`, `!=`, `<`, `>`
* Numbers → `-eq`, `-lt`, `-gt`, `-ge`, `-le`, `-ne`
* Files → `-f`, `-d`, `-e`, etc.
* Logic → `&&`, `||`, `!`
